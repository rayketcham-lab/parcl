<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui"
          onLoad="Ribbon_Load"
          loadImage="GetButtonImage">
  <ribbon>
    <tabs>
      <tab id="ParclTab" label="Parcl" insertAfterMso="TabMail">
        <group id="grpSecurity" label="Security">
          <toggleButton id="btnEncrypt"
                        label="Encrypt"
                        screentip="Encrypt this message"
                        supertip="Toggle S/MIME encryption. When pressed, the message will be encrypted on send."
                        size="large"
                        image="btnEncrypt"
                        onAction="OnEncryptToggle"
                        getPressed="GetEncryptPressed" />
          <button id="btnDecrypt"
                  label="Decrypt"
                  screentip="Decrypt this message"
                  supertip="Decrypt an encrypted message using your private key."
                  size="large"
                  image="btnDecrypt"
                  onAction="OnDecryptClick" />
          <toggleButton id="btnSign"
                        label="Sign"
                        screentip="Digitally sign this message"
                        supertip="Toggle S/MIME signature. When pressed, the message will be signed on send."
                        size="large"
                        image="btnSign"
                        onAction="OnSignToggle"
                        getPressed="GetSignPressed" />
        </group>
        <group id="grpCertificates" label="Certificates">
          <button id="btnCertExchange"
                  label="Send Certificate"
                  screentip="Send your certificate"
                  supertip="Attach your public certificate to this message so the recipient can send you encrypted email."
                  size="large"
                  image="btnCertExchange"
                  onAction="OnCertExchangeClick" />
          <button id="btnCertSelector"
                  label="Select Certificates"
                  screentip="Choose your certificates"
                  supertip="Select which certificates to use for signing and encryption."
                  size="large"
                  image="btnCertSelector"
                  onAction="OnCertSelectorClick" />
          <button id="btnLookup"
                  label="Lookup"
                  screentip="Lookup recipient certificates"
                  supertip="Search LDAP directories for recipient encryption certificates."
                  size="normal"
                  image="btnLookup"
                  onAction="OnLookupClick" />
        </group>
        <group id="grpSettings" label="Settings">
          <toggleButton id="btnDashboard"
                        label="Dashboard"
                        screentip="Toggle Parcl Dashboard"
                        supertip="Show or hide the animated Parcl security dashboard panel."
                        size="large"
                        image="btnDashboard"
                        onAction="OnDashboardToggle"
                        getPressed="GetDashboardPressed" />
          <button id="btnOptions"
                  label="Options"
                  screentip="Parcl Options"
                  supertip="Configure LDAP directories, crypto preferences, and add-in behavior."
                  size="large"
                  image="btnOptions"
                  onAction="OnOptionsClick" />
        </group>
      </tab>
    </tabs>
  </ribbon>

  <!-- Right-click context menus -->
  <contextMenus>
    <!-- Context menu for compose (new/reply/forward) messages -->
    <contextMenu idMso="ContextMenuMailItem">
      <menuSeparator id="ParclSepCompose" />
      <menu id="ParclCtxCompose" label="Parcl" image="btnEncrypt">
        <button id="ctxEncrypt"
                label="Encrypt"
                image="btnEncrypt"
                onAction="OnEncryptClick" />
        <button id="ctxSign"
                label="Sign"
                image="btnSign"
                onAction="OnSignClick" />
        <menuSeparator id="ParclCtxSep1" />
        <button id="ctxRemoveEncrypt"
                label="Remove Encryption"
                image="btnDecrypt"
                onAction="OnRemoveEncryptionClick" />
        <button id="ctxRemoveSign"
                label="Remove Signature"
                image="btnDecrypt"
                onAction="OnRemoveSignatureClick" />
        <menuSeparator id="ParclCtxSep2" />
        <button id="ctxSendCert"
                label="Send Certificate"
                image="btnCertExchange"
                onAction="OnCertExchangeClick" />
      </menu>
    </contextMenu>

    <!-- Context menu for read-only (received) messages -->
    <contextMenu idMso="ContextMenuReadOnlyMailItem">
      <menuSeparator id="ParclSepRead" />
      <menu id="ParclCtxRead" label="Parcl" image="btnDecrypt">
        <button id="ctxEncryptAtRest"
                label="Encrypt (Lock)"
                image="btnEncrypt"
                onAction="OnEncryptClick" />
        <button id="ctxDecrypt"
                label="Decrypt"
                image="btnDecrypt"
                onAction="OnDecryptClick" />
      </menu>
    </contextMenu>
  </contextMenus>
</customUI>
