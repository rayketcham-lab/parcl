<UserControl x:Class="Parcl.Addin.Animations.CertificateBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="32" Height="32">

    <UserControl.Resources>
        <Storyboard x:Key="ValidAnimation">
            <!-- Scale bounce in -->
            <DoubleAnimation Storyboard.TargetName="BadgeScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BadgeScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <!-- Color to green -->
            <ColorAnimation Storyboard.TargetName="BadgeCircle"
                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                            To="#00E676" Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Key="ExpiredAnimation">
            <DoubleAnimation Storyboard.TargetName="BadgeScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0" To="1" Duration="0:0:0.3" />
            <DoubleAnimation Storyboard.TargetName="BadgeScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0" To="1" Duration="0:0:0.3" />
            <ColorAnimation Storyboard.TargetName="BadgeCircle"
                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                            To="#FF5252" Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Key="WarningAnimation" RepeatBehavior="3x">
            <ColorAnimation Storyboard.TargetName="BadgeCircle"
                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                            To="#FFC107" Duration="0:0:0.4"
                            AutoReverse="True" />
        </Storyboard>
    </UserControl.Resources>

    <Grid RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="BadgeScale" ScaleX="0" ScaleY="0" />
        </Grid.RenderTransform>

        <Ellipse x:Name="BadgeCircle"
                 Width="28" Height="28"
                 Fill="#8892B0" />

        <!-- Certificate icon (simplified) -->
        <Path Data="M 16,6 L 16,6 A 5,5 0 1 0 16,6.01 M 12,18 L 20,18 M 12,22 L 18,22"
              Stroke="White" StrokeThickness="1.5"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
    </Grid>
</UserControl>
