<UserControl x:Class="Parcl.Addin.Animations.SpinnerRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="40" Height="40">

    <UserControl.Resources>
        <Storyboard x:Key="SpinStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinTransform"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360"
                             Duration="0:0:1.2" />
        </Storyboard>

        <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="0.8" Duration="0:0:0.8"
                             AutoReverse="True" />
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Pulse glow -->
        <Ellipse x:Name="PulseGlow"
                 Width="44" Height="44"
                 Opacity="0.3"
                 Margin="-2">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#444FC3F7" Offset="0.6" />
                    <GradientStop Color="#004FC3F7" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Track ring -->
        <Ellipse Width="36" Height="36"
                 Stroke="#22FFFFFF" StrokeThickness="3"
                 Margin="2" />

        <!-- Spinning arc -->
        <Path Stroke="#4FC3F7" StrokeThickness="3"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Margin="2"
              RenderTransformOrigin="0.5,0.5">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="18,0" IsClosed="False">
                        <ArcSegment Point="36,18" Size="18,18"
                                    SweepDirection="Clockwise" IsLargeArc="False" />
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
            <Path.RenderTransform>
                <RotateTransform x:Name="SpinTransform" Angle="0" />
            </Path.RenderTransform>
        </Path>
    </Grid>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinStoryboard}" />
            <BeginStoryboard Storyboard="{StaticResource PulseStoryboard}" />
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
